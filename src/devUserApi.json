          "studentId": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "role": {
            "$ref": "#/components/schemas/SystemRoleEnum"
          },
          "isActive": {
            "type": "boolean",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Enter 'Bearer {token}' (including the word 'Bearer' and a space) in the Authorization header.",
        "name": "Authorization",
        "in": "header"
