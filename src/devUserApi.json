            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "orcid": {
            "maxLength": 50,
            "minLength": 0,
