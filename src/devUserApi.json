  "components": {
    "schemas": {
      "AddCheckingLogRequest": {
        "required": [
          "checkingTime",
          "studentId"
        ],
        "type": "object",
        "properties": {
          "studentId": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string"
          },
          "checkingTime": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "AddUserRequest": {
        "required": [
          "email",
          "fullName"
        ],
        "type": "object",
        "properties": {
          "email": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "format": "email"
          },
          "fullName": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string"
          },
          "phoneNumber": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "orcid": {
            "maxLength": 50,
            "minLength": 0,
            "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$",
            "type": "string",
            "nullable": true
          },
          "googleScholarUrl": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "githubUrl": {
            "maxLength": 255,
            "minLength": 0,
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "studentId": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "role": {
            "$ref": "#/components/schemas/SystemRoleEnum"
          }
        },
        "additionalProperties": false
      },
      "ExchangeGoogleCodeRequest": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "nullable": true
          },
          "redirectUri": {
            "type": "string",
            "nullable": true
          },
          "codeVerifier": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GoogleLoginRequest": {
        "type": "object",
        "properties": {
          "idToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SystemRoleEnum": {
        "enum": [
          1,
          2,
          3,
          4,
          5
        ],
        "type": "integer",
        "format": "int32"
      },
      "UpdateGoogleCredentialRequest": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "nullable": true
          },
          "refreshToken": {
            "type": "string",
            "nullable": true
          },
          "expiresAtUtc": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "phoneNumber": {
            "maxLength": 20,
            "minLength": 0,
            "type": "string",
            "nullable": true
          },
          "orcid": {
            "maxLength": 50,
            "minLength": 0,
            "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[0-9X]$",
